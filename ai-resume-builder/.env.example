# Copy to .env.local for local dev. On Render, add these in the Static Site env (build-time).

VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key
VITE_STRAPI_API_URL=http://localhost:1337/api
VITE_STRAPI_API_KEY=your_strapi_api_token
VITE_ATS_API_URL=https://nexume-ats-api.onrender.com
VITE_GOOGLE_AI_API_KEY=your_key_from_ai_google_dev
# Use API model id (lowercase, hyphens) — NOT the display name from AI Studio
VITE_GEMINI_MODEL=gemini-3.1-flash-lite
