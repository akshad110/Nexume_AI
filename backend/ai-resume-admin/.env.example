HOST=0.0.0.0
PORT=1337

# Generate: openssl rand -base64 32 (use 4 comma-separated values for APP_KEYS)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change_me
ADMIN_JWT_SECRET=change_me
TRANSFER_TOKEN_SALT=change_me
JWT_SECRET=change_me
ENCRYPTION_KEY=change_me

# Local SQLite (dev only — use Postgres on Render)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Render PostgreSQL (production)
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_SSL=true

# Comma-separated frontend URLs (no trailing slash)
CORS_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com

NODE_ENV=production
