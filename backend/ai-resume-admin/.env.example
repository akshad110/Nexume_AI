HOST=0.0.0.0
PORT=1337

# Generate: openssl rand -base64 32 (use 4 comma-separated values for APP_KEYS)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change_me
ADMIN_JWT_SECRET=change_me
TRANSFER_TOKEN_SALT=change_me
JWT_SECRET=change_me
ENCRYPTION_KEY=change_me

# --- LOCAL (MySQL on your PC) — do NOT copy these to Render ---
# DATABASE_CLIENT=mysql
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=3306
# DATABASE_NAME=resumebuilder
# DATABASE_USERNAME=root
# DATABASE_PASSWORD=your_local_password
# DATABASE_SSL=false

# --- RENDER (PostgreSQL) — use Internal Database URL from Render Postgres ---
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_SSL=true
# Remove DATABASE_HOST, DATABASE_PORT, DATABASE_NAME, DATABASE_USERNAME, DATABASE_PASSWORD on Render

# Comma-separated frontend URLs (no trailing slash)
CORS_ORIGINS=http://localhost:5173,https://nexume-ai-x9gr.onrender.com
NODE_ENV=production
